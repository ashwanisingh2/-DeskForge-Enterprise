generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String               @id @default(cuid())
  slug            String               @unique
  name            String
  mode            String               @default("single")
  timezone        String               @default("UTC")
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  users           User[]
  tickets         Ticket[]
  kbArticles      KBArticle[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  slaConfigs      SLAConfig[]
  cannedResponses CannedResponse[]
  assets          Asset[]
  changes         ChangeRequest[]
  problems        Problem[]
  catalogItems    ServiceCatalogItem[]
  timeEntries     TimeEntry[]
  loginEvents     LoginEvent[]
}

model User {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  username         String          @unique
  password         String
  role             Role            @default(END_USER)
  department       String?
  phone            String?
  isActive         Boolean         @default(true)
  avatar           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  assignedTickets  Ticket[]        @relation("AssignedTo")
  requestedTickets Ticket[]        @relation("RequestedBy")
  comments         Comment[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  activityLogs     ActivityLog[]
  ownedAssets      Asset[]         @relation("AssetOwner")
  timeEntries      TimeEntry[]
  requestedChanges ChangeRequest[] @relation("ChangeRequester")
  ownedProblems    Problem[]       @relation("ProblemOwner")
  loginEvents      LoginEvent[]

  @@index([tenantId, role, isActive])
}

model Ticket {
  id              String            @id
  title           String
  description     String            @db.Text
  status          TicketStatus      @default(OPEN)
  priority        Priority          @default(MEDIUM)
  category        String
  subcategory     String?
  impact          String?
  urgency         String?
  source          String?
  tags            String[]          @default([])
  assigneeId      String?
  assignee        User?             @relation("AssignedTo", fields: [assigneeId], references: [id])
  requesterId     String
  requester       User              @relation("RequestedBy", fields: [requesterId], references: [id])
  dueDate         DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  firstResponseAt DateTime?
  slaStatus       SLAStatus         @default(ON_TRACK)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  comments        Comment[]
  attachments     Attachment[]
  activityLogs    ActivityLog[]
  relatedTo       RelatedTicket[]   @relation("TicketA")
  relatedFrom     RelatedTicket[]   @relation("TicketB")
  timeEntries     TimeEntry[]
  problemLinks    ProblemIncident[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, assigneeId, status])
  @@index([tenantId, requesterId, createdAt])
  @@index([tenantId, dueDate, slaStatus])
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  isInternal Boolean  @default(false)
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action    String
  detail    String?
  oldValue  String?
  newValue  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Attachment {
  id          String   @id @default(cuid())
  filename    String
  url         String
  objectKey   String   @unique
  contentType String
  size        Int
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model KBArticle {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  category   String
  status     String   @default("published")
  views      Int      @default(0)
  helpfulYes Int      @default(0)
  helpfulNo  Int      @default(0)
  authorId   String
  tags       String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, category])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  ticketId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, userId, isRead, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId, createdAt])
}

model SLAConfig {
  id                String @id @default(cuid())
  priority          String
  responseTimeHrs   Int
  resolutionTimeHrs Int
  tenantId          String
  tenant            Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, priority])
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String?
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
}

model RelatedTicket {
  id           String @id @default(cuid())
  ticketAId    String
  ticketBId    String
  relationship String
  ticketA      Ticket @relation("TicketA", fields: [ticketAId], references: [id])
  ticketB      Ticket @relation("TicketB", fields: [ticketBId], references: [id])

  @@unique([ticketAId, ticketBId])
}

model Asset {
  id            String           @id @default(cuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  assetTag      String
  name          String
  type          String
  serialNumber  String?
  status        String           @default("OPERATIONAL")
  ownerId       String?
  owner         User?            @relation("AssetOwner", fields: [ownerId], references: [id])
  purchaseDate  DateTime?
  warrantyEnd   DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  relationships CIRelationship[] @relation("CISource")
  relatedFrom   CIRelationship[] @relation("CITarget")

  @@unique([tenantId, assetTag])
  @@index([tenantId, type, status])
}

model CIRelationship {
  id       String @id @default(cuid())
  sourceId String
  targetId String
  type     String
  source   Asset  @relation("CISource", fields: [sourceId], references: [id], onDelete: Cascade)
  target   Asset  @relation("CITarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
}

model ChangeRequest {
  id                 String     @id
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  title              String
  description        String     @db.Text
  type               String
  status             String     @default("DRAFT")
  risk               String
  implementationPlan String     @db.Text
  rollbackPlan       String     @db.Text
  windowStart        DateTime?
  windowEnd          DateTime?
  requesterId        String
  requester          User       @relation("ChangeRequester", fields: [requesterId], references: [id])
  approvals          Approval[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([tenantId, status, windowStart])
}

model Approval {
  id         String        @id @default(cuid())
  changeId   String
  change     ChangeRequest @relation(fields: [changeId], references: [id], onDelete: Cascade)
  approverId String
  status     String        @default("PENDING")
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime      @default(now())

  @@unique([changeId, approverId])
}

model Problem {
  id           String            @id
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  title        String
  description  String            @db.Text
  status       String            @default("INVESTIGATING")
  rootCause    String?           @db.Text
  workaround   String?           @db.Text
  permanentFix String?           @db.Text
  ownerId      String
  owner        User              @relation("ProblemOwner", fields: [ownerId], references: [id])
  incidents    ProblemIncident[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([tenantId, status])
}

model ProblemIncident {
  problemId String
  ticketId  String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([problemId, ticketId])
}

model ServiceCatalogItem {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  description     String   @db.Text
  category        String
  formSchema      Json
  approvalSchema  Json?
  fulfillmentTeam String?
  deliveryHours   Int?
  cost            Decimal? @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, category, isActive])
}

model TimeEntry {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  ticketId        String
  ticket          Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  workDate        DateTime
  durationMinutes Int
  description     String
  workType        String
  billable        Boolean   @default(false)
  hourlyRate      Decimal?  @db.Decimal(12, 2)
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId, userId, workDate])
}

model LoginEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  username  String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([username, createdAt])
  @@index([tenantId, userId, createdAt])
}

enum Role {
  ADMIN
  AGENT
  END_USER
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SLAStatus {
  ON_TRACK
  AT_RISK
  BREACHED
}
